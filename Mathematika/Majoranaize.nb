Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MyDot", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], " ", ":=", 
   RowBox[{"(", " ", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], 
       RowBox[{"Ln", "/", "2"}]], 
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "k", "]"}], "]"}], 
       RowBox[{"y", "[", 
        RowBox[{"[", "k", "]"}], "]"}]}]}], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "Ln"}], 
       RowBox[{"Ln", "*", 
        RowBox[{"3", "/", "2"}]}]], 
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"[", "k", "]"}], "]"}], 
       RowBox[{"y", "[", 
        RowBox[{"[", "k", "]"}], "]"}]}]}]}], ")"}]}], ";"}]], "Input",
