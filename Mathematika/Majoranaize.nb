Cell[BoxData[
 RowBox[{
  RowBox[{"MyPlot2", "[", "V_", "]"}], " ", ":=", " ", 
  RowBox[{"ArrayPlot", "[", 
   RowBox[{
    RowBox[{"Partition", "[", 
     RowBox[{"V", ",", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Length", "[", "V", "]"}], "]"}]}], "]"}], ",", 
    RowBox[{"ColorFunction", "\[Rule]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Hue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Pi]", "+", 
            RowBox[{"Arg", "[", "#", "]"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "\[Pi]"}], ")"}]}], " ", ",", "1", ",", 
         RowBox[{"1", "-", 
          RowBox[{"1", "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{
              RowBox[{"Abs", "[", "#", "]"}], "^", 
              RowBox[{"(", ".2", ")"}]}]}], ")"}]}]}]}], "]"}], "&"}], 
      ")"}]}], ",", 
